# ============================================================
#  ENVIRONMENT CONFIG
#  Copy file ini jadi ".env" lalu isi sesuai lingkungan lu.
#  JANGAN commit file .env ke git.
# ============================================================

APP_NAME="Digital Printing"
APP_ENV=local           # local | production
APP_DEBUG=true          # true saat development, false saat produksi
APP_URL=http://localhost:8000

# ---------- Database (MySQL) ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=digital_printing
DB_USER=root
DB_PASS=

# ---------- Session ----------
SESSION_NAME=dp_session
